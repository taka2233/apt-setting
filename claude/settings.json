{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cut:*)",
      "Bash(go build:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(wc:*)",
      "Bash(go fmt ./...)",
      "Bash(gofmt -w *)",
      "Bash(gofmt -l *)",
      "Bash(gofmt -d *)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(svn:*)",
      "Bash(hg:*)",
      "Bash(bzr:*)",
      "Bash(darcs:*)",
      "Bash(fossil:*)",
      "Bash(gofmt -r *)",
      "Bash(mercurial:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "refreshInterval": 180
  },
  "effortLevel": "high"
}
